{
  "env": {
    "browser": true,
    "es6": true,
    "commonjs": true,
    "node": true
  },
  "rules": {
    "import/first": 1,
    "no-native-reassign": 0,
    "no-negated-in-lhs": 0,
    "no-unreachable": 1,
    "no-console": 0,
    "prefer-const": 0,
    "no-use-before-define": 0,
    "no-restricted-globals": 1
  },
  "extends": [],
  "parser": "",
  "root": true,
  "plugins": [],
  "parserOptions": {
    "ecmaVersion": 11,
    "ecmaFeatures": {}
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
